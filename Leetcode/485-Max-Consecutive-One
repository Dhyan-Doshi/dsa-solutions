class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int MaxNum=0;
        int n=nums.size(); 
        int second=0;
        for(int i=0;i<n;i++){
            if(nums[i]==1){
                second++;   
                MaxNum=max(second,MaxNum);
            }
            else{
                second=0;
            }
        }
        return MaxNum;
    }
};