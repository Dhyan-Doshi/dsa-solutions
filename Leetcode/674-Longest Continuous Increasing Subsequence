class Solution {
public:
    int findLengthOfLCIS(vector<int>& nums) {
        int n=nums.size();
        int MaxLen=1;
        int second=1;
        for(int i=0;i<n-1;i++){
            if(nums[i]<nums[i+1]){
                second++;
                MaxLen=max(MaxLen,second);
            }else{
                second=1;
            }
        }
        return MaxLen;
    }
};