class Solution {
public:
    int removeElement(vector<int>& nums, int val) {
        int n=nums.size();
        //int st=0;
        //int end=n-1;
        //while(st<=end)
        for(int i=0;i<n; ){
            if(nums[i]==val){
                nums.erase(nums.begin()+i);
                n--;
            }else{
                i++;
            }
        }
        return nums.size();
    }
};