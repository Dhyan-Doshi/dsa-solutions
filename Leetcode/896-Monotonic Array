class Solution {
public:
    bool isMonotonic(vector<int>& nums) {
        int n=nums.size();
        int inc=true;
        int dec=true;
        for(int i=0;i<n-1;i++){
            if(nums[i]<nums[i+1]){
                dec=false;
            }
            else if(nums[i]>nums[i+1]){
                inc =false;
            }
        }
        return inc || dec;
    }
};