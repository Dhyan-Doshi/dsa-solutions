class Solution {
public:
    int dominantIndex(vector<int>& nums) {
        int n=nums.size();
        int Lar=*max_element(nums.begin(),nums.end());
        int a=find(nums.begin(), nums.end(), Lar)-nums.begin();
        for(int i=0;i<n;i++){
            if(a==i){
                continue;
            }
            if(Lar<2*nums[i]){ 
                return -1;
            }
        }
        return a;
    }
};