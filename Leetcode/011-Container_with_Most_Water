class Solution {
public:
    int maxArea(vector<int>& height) {
        int n=height.size();
        int st=0, end=n-1;
        int max_area=0;
        while(st<end){
            int ht=min(height[st],height[end]);
            int wt=end-st;
            int area=ht*wt;
            max_area=max(area,max_area);
            if(height[st]<height[end]){
                st++;
            }else{
                end--;
            }
        }
        return max_area;
    }

};