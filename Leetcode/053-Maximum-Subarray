class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int size=nums.size()-1;
        int currentsum=0;
        int max_sum=INT_MIN;
        for(int i=0;i<=size;i++){
            currentsum+=nums[i];
            max_sum=max(max_sum,currentsum);
            if(currentsum<0){
                currentsum=0;
            }
        }
        return max_sum;
    }
};