class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n=nums.size();
        int k=0;
        for(int i=0;i<n-1; ){
            if(nums[i]==nums[i+1]){
                nums.erase(nums.begin()+(i+1));
                n--;
            }else{
                i++;
            }
        }
        return nums.size();
    }
};