class Solution {
public:
    int mySqrt(int x) {
        int st=1;
        int end=x;
        int ans=0;
        while(st<=end){
            long long mid=st+(end-st)/2;
            long long sq=mid*mid;
            if(sq==x){
                return mid;
            }else if(sq>x){
                end=end=mid-1;
            }else{
                ans=mid;
                st=mid+1;
            }
        }
        return ans;
    }
};